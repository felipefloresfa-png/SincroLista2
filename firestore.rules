rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function getUserFamilyId() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId; }

    // 1. Users
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming())
                    && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'favoriteItems', 'familyId']);
      
      function isValidUser(data) {
        return data.uid == request.auth.uid
          && data.displayName is string && data.displayName.size() <= 100
          && data.familyId is string && data.familyId.size() <= 50;
      }
    }

    // 2. Lists
    match /lists/{listId} {
      allow read: if isSignedIn() && (existing().familyId == getUserFamilyId() || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && incoming().familyId == getUserFamilyId() && isValidList(incoming());
      allow update: if isSignedIn() && (existing().familyId == getUserFamilyId() || isAdmin()) && isValidList(incoming())
                    && (isAdmin() || incoming().familyId == existing().familyId);
      allow delete: if isSignedIn() && (existing().familyId == getUserFamilyId() || isAdmin());

      function isValidList(data) {
        return data.name is string && data.name.size() <= 100
          && data.familyId is string && data.familyId.size() <= 50;
      }
    }

    // 3. Items
    match /items/{itemId} {
      allow read: if isSignedIn() && (resource.data.familyId == getUserFamilyId() || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && incoming().familyId == getUserFamilyId() && isValidItem(incoming());
      allow update: if isSignedIn() && (existing().familyId == getUserFamilyId() || isAdmin()) && isValidItem(incoming())
                    && (isAdmin() || incoming().familyId == existing().familyId);
      allow delete: if isSignedIn() && (existing().familyId == getUserFamilyId() || isAdmin());

      function isValidItem(data) {
        return data.name is string && data.name.size() <= 100
          && data.familyId is string && data.familyId.size() <= 50
          && data.listId is string && data.listId.size() <= 50;
      }
    }

    // Admins helper
    match /admins/{adminId} {
      allow read: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
    }

    // 4. Activities
    match /activities/{activityId} {
      allow read: if isSignedIn() && resource.data.familyId == getUserFamilyId();
      allow create: if isSignedIn() && incoming().familyId == getUserFamilyId();
      allow delete: if isSignedIn() && existing().familyId == getUserFamilyId();
    }

    // 5. History
    match /history/{historyId} {
      allow read: if isSignedIn() && resource.data.familyId == getUserFamilyId();
      allow create: if isSignedIn() && incoming().familyId == getUserFamilyId() && isValidHistory(incoming());
      allow update: if isSignedIn() && existing().familyId == getUserFamilyId() && isValidHistory(incoming())
                    && incoming().familyId == existing().familyId;
      allow delete: if isSignedIn() && existing().familyId == getUserFamilyId();

      function isValidHistory(data) {
        return data.familyId is string && data.familyId.size() <= 50
          && (data.totalCost == null || data.totalCost is number)
          && (data.storeName == null || (data.storeName is string && data.storeName.size() <= 100));
      }
    }
  }
}
